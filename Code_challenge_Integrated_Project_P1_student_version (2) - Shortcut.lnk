# MARKET ANALYSIS
#our business question 1
#How many orders do we have in our system?
SELECT COUNT(*) AS Total_Orders
FROM orders;
# The total orders the company have so far in the systemm 
#per our dataset is 180516

# 2. Which markets does our company operate in?
SELECT DISTINCT Market
FROM orders;
# The company operates across five major global markets:
# Africa, Europe, LATAM (Latin America), Pacific Asia, and USCA. 
#This indicates the business has an international customer base and a diverse geographic presence

# 3. I only want to see markets that have more than 20,000 orders.
SELECT Market,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY Market
HAVING COUNT(*) > 20000
ORDER BY Total_Orders DESC;
#Four of the company's five markets have processed more than 20,000 orders.
#Africa is the only market below this threshold,
#indicating that it has significantly lower order volume 
# and may present an opportunity for business growth or further investigation.

#4. Show me orders from Africa, Europe, and LATAM only.
SELECT `Order Id`,
       Market,
       Sales
FROM orders
WHERE Market IN ('Africa', 'Europe', 'LATAM');

Select `Order Id`,
       Market,
       Sales
       from orders
       where market IN ( 'USCA', 'Pacific Asia' );

#. Business Question 2
# 1. How many orders came from the African market
SELECT COUNT(*) AS Africa_Orders
FROM orders
WHERE Market = 'Africa';
#Approximately 11,614 orders came from the african market 

#2. How many orders came from Europe?
SELECT COUNT(*) AS Europe_Orders
FROM orders
WHERE Market = 'Europe';
#50250 came from the european orders 

#3. Which markets have the most orders?
SELECT Market,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY Market
ORDER BY Total_Orders DESC;
#LATAM is our strongest market by order volume, while Africa has the lowest number of orders. 
#This suggests there may be opportunities to grow our presence
# in the African market or investigate why order volumes are lower compared to other regions.

#4.  Which market generated the highest total sales? Show me the total sales generated by each market
SELECT Market,
       SUM(Sales) AS Total_Sales
FROM orders
GROUP BY Market
ORDER BY Total_Sales DESC;
# Eropen had the most sales out of the five markets, whcih recorded 
# 10871786.81, as compared to the Africa market  with the least 
# number of sales with 2294452.92

# 5. If Europe has the highest sales, is it because each order is worth more?
# "How much money did each market make on average?"
SELECT Market,
       AVG(Sales) AS Average_Sales
FROM orders
GROUP BY Market
ORDER BY Average_Sales DESC;
# Europe appears to generate higher-value orders than the other markets.
# Although LATAM processes more orders, the average value of each European order
# is higher, leading Europe to generate the greatest overall sales.

# *** CUSTOMER SEGMENT ANALYSIS ****
#1. "Which customer segment places the most orders?
SELECT `Customer Segment`,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY `Customer Segment`
ORDER BY Total_Orders DESC;

#2 Which customer segment generates the highest revenue?
SELECT `Customer Segment`,
       Round(sum(Sales),2) AS Total_sales
FROM orders
GROUP BY `Customer Segment`
ORDER BY Total_Sales DESC;
# The Consumer segment is the company's strongest revenue-generating customer group, 
# contributing approximately 19.1 million in sales.
# In contrast, the Home Office segment contributes the least revenue at approximately 6.52 million. 
# This suggests that the Consumer segment should remain a strategic focus for marketing and customer retention,
# while the Home Office segment may require targeted initiatives to increase sales.
# Some customer names are stored in different letter cases. Can you standardize them?
SELECT `Customer Fname`,
       UPPER(`Customer Fname`) AS Upper_Name
FROM orders
LIMIT 10;
SELECT `Customer Fname`,
       LOWER(`Customer Fname`) AS Lower_Name
FROM orders
LIMIT 10;
#Find the number of characters in a string.
SELECT `Customer Fname`,
       LENGTH(`Customer Fname`) AS Name_Length
FROM orders
LIMIT 10;
# when we want to join two columns together 
SELECT CONCAT(`Customer Fname`, ' ', `Customer Lname`) AS Full_Name
FROM orders
LIMIT 10;
#if we want to spli
SELECT
    SUBSTRING_INDEX(Full_Name, ' ', 1) AS First_Name,
    SUBSTRING_INDEX(Full_Name, ' ', -1) AS Last_Name
FROM customers;
# for dates too 
SELECT
    SUBSTRING_INDEX(`order date (DateOrders)`, ' ', 1) AS Order_Date,
    SUBSTRING_INDEX(`order date (DateOrders)`, ' ', -1) AS Order_Time
FROM orders;

#Display each customer's first name, last name, full name, and the length of the full name
SELECT
    `Customer Fname` AS First_Name,
    `Customer Lname` AS Last_Name,
    CONCAT(`Customer Fname`, ' ', `Customer Lname`) AS Full_Name,
    LENGTH(CONCAT(`Customer Fname`, ' ', `Customer Lname`)) AS Full_Name_Length
FROM orders
LIMIT 10;

#to correct the emailsnincase theres mistakes
SELECT
    REPLACE(`Customer Email`, '@', ' [at] ') AS Modified_Email
FROM orders
LIMIT 10;

#A JOIN connects two or more tables using a common column (usually an ID)
# Show me every order together with the customer's name and the product they bought.
# first create Create a Customers Table
CREATE TABLE customers AS
SELECT DISTINCT
    `Customer Id`,
    `Customer Fname`,
    `Customer Lname`,
    Market
FROM orders;

# Product Table
CREATE TABLE products AS
SELECT DISTINCT
    `Product Card Id`,
    `Product Name`,
    `Category Name`
FROM orders;

#ordersb table
CREATE TABLE sales_orders AS
SELECT
    `Order Id`,
    `Customer Id`,
    `Product Card Id`,
    Sales
FROM orders;
# the final query 
SELECT
    so.`Order Id`,
    CONCAT(c.`Customer Fname`, ' ', c.`Customer Lname`) AS Customer_Name,
    p.`Product Name`,
    so.Sales
FROM sales_orders so
INNER JOIN customers c
    ON so.`Customer Id` = c.`Customer Id`
INNER JOIN products p
    ON so.`Product Card Id` = p.`Product Card Id`;




# ******* COUNTRY ANALYSIS ****** 
# 1. How many African orders had sales greater than 500?
SELECT Market, 
round(sales,2) as africa_orders
FROM orders
WHERE Market = 'Africa'
LIMIT 10;

#2.******* How many African orders had THE Maximum sales******
SELECT MAX(Sales) AS Highest_Africa_Sale
FROM orders
WHERE Market = 'Africa';

# 3. I want to know which countries generate the most orders. Show me the Top 10 countries.
SELECT `Order Country`,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY `Order Country`
ORDER BY Total_Orders DESC
LIMIT 10;

#4.  Which 10 countries generated the highest total sales?
SELECT `Order Country`,
       ROUND(SUM(Sales), 2) AS Total_Sales
FROM orders
GROUP BY `Order Country`
ORDER BY Total_Sales DESC
LIMIT 10;
# The United States (Estados Unidos) is the company's highest revenue-generating country,
# contributing approximately 4.88 million in total sales. 
# This indicates that the U.S. market is a key driver of business 
# performance and should remain a strategic priority for customer retention and market expansion

# ****** PRODUCT ANALYSIS*****
# 1. Which product category generates the highest sales?
# Which product categories generate the most revenue? We need to know where to invest our marketing budget
SELECT `Category Name`,
       ROUND(SUM(Sales), 2) AS Total_Sales
FROM orders
GROUP BY `Category Name`
ORDER BY Total_Sales DESC;

#2.  How many product categories do we have?
SELECT COUNT(DISTINCT `Category Name`) AS Total_Categories
FROM orders;

#3.  Which 10 products generate the highest sales?
Select `Product Name`, 
ROUND(SUM(Sales), 2) AS Total_Sales
from orders
Group by `Product Name`
order by total_sales Desc
limit 10;
#The 'Field & Stream Sportsman 16 Gun Fire Safe' is the company's highest revenue-generating product,
#contributing approximately 6.93 million in sales. 
# This suggests it is a flagship product and should be prioritized for inventory planning, 
# marketing campaigns, and customer retention strategies

#4.  I want to find all products whose names contain the word 'Nike'.
# We're planning a promotion for Nike products.
SELECT `Product Name`,
       Sales
FROM orders
WHERE `Product Name` LIKE '%Nike%';
# The query successfully identified all products containing 'Nike' in their names along with their sales values. 
# This allows the marketing team to evaluate the performance of Nike products
#  and make informed decisions about promotions, pricing strategies, or inventory planning.

SELECT `Product Name`,
       round ((sales),2) as Sales
FROM orders
WHERE `Product Name` LIKE '%Nike%'
And sales > 200
order by Sales desc;


# ****** SALES ANALYSIS ****
# What is the highest sale we've ever recorded, and what is the lowest?
SELECT round(MAX(Sales),2) AS Highest_Sale
FROM orders;
SELECT round(MIN(Sales),2) AS Highest_Sale
FROM orders;

# Which market has the highest average sale, but only include markets where the average sale is greater than 160
Select market,
Round(Avg(sales),2) as Avg_sales
from orders 
group by market
having avg_sales > 160
order by avg_sales desc;

# Show me all orders where the sales were between 100 and 300.
SELECT `Order Id`,
       `Product Name`,
       Sales
FROM orders
WHERE Sales BETWEEN 100 AND 300;

# Approximately how many rows matched the condition?
SELECT COUNT(*) AS Orders_Between_100_And_300
FROM orders
WHERE Sales BETWEEN 100 AND 300;

# What kinds of products appear most often?
SELECT `Category Name`,
       COUNT(*) AS Total_Orders
FROM orders
WHERE Sales BETWEEN 100 AND 300
GROUP BY `Category Name`
ORDER BY Total_Orders DESC;
# Most orders with sales between 100 and 300 come from the Mens footwear,
# indicating that Fishing products are a major contributor within this sales range

#How many orders are between 100 and 300?
SELECT COUNT(*) AS Orders_Between_100_And_300
FROM orders
WHERE Sales BETWEEN 100 AND 300;

#Which category appears most often?
SELECT `Category Name`,
       COUNT(*) AS Total_Orders
FROM orders
WHERE Sales BETWEEN 100 AND 300
GROUP BY `Category Name`
ORDER BY Total_Orders DESC;
#This query identifies which product categories contribute the most orders within the 100–300 sales range.
# It helps the business understand which product lines dominate medium-value
# purchases and where marketing or inventory efforts may be focused.

# I don't want to see raw sales figures anymore.
# I want every order classified as High Value, Medium Value, or Low Value.
SELECT `Order Id`,
       `Product Name`,
       Sales,
       CASE
           WHEN Sales >= 500 THEN 'High Value'
           WHEN Sales >= 200 THEN 'Medium Value'
           ELSE 'Low Value'
       END AS Sales_Category
FROM orders
LIMIT 20;

# How many High Value, Medium Value, and Low Value orders do we have?
SELECT
    CASE
        WHEN Sales >= 500 THEN 'High Value'
        WHEN Sales >= 200 THEN 'Medium Value'
        ELSE 'Low Value'
    END AS Sales_Category,
    COUNT(*) AS Total_Orders
FROM orders
GROUP BY Sales_Category
ORDER BY Total_Orders DESC;

# ***  DATE ANALYSIS
# Which year did we receive the most orders?
SELECT YEAR(`order date (DateOrders)`) AS Order_Year,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY Order_Year
ORDER BY Total_Orders DESC;






